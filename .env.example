# Скопируйте в .env и заполните значения. Файл .env в репозиторий не коммитьте.

# Токен бота: @BotFather
TELEGRAM_BOT_TOKEN=

# ID чата или супергруппы менеджеров (лиды / продажи; для супергрупп часто отрицательный)
OPERATOR_CHAT_ID=

OPENAI_API_KEY=

# Любая модель с Chat Completions, поддерживающая response_format json_schema
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_BASE_URL=https://api.openai.com/v1

# Вариант системного промпта: default | alt (A/B, укороченный чеклист)
PROMPT_VARIANT=default

LOG_LEVEL=INFO

# Опционально: URL вебхука CRM / Zapier / Make — POST JSON после отправки лида в Telegram
# CRM_WEBHOOK_URL=
# Секрет для заголовка Authorization: Bearer … (если не нужен — оставьте пустым)
# CRM_WEBHOOK_SECRET=
