# Скопируйте в .env и заполните значения. Файл .env в репозиторий не коммитьте.

# Токен бота: @BotFather
TELEGRAM_BOT_TOKEN=

# ID чата или супергруппы операторов (часто отрицательный для супергрупп)
OPERATOR_CHAT_ID=

OPENAI_API_KEY=

# Любая модель с Chat Completions, поддерживающая response_format json_schema
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_BASE_URL=https://api.openai.com/v1

LOG_LEVEL=INFO
